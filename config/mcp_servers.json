{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "description": "MCP Server 配置文件 - 管理所有 MCP (Model Context Protocol) Server",
  "version": "1.0",
  "servers": [
    {
      "name": "playwright",
      "description": "浏览器自动化 - 提供网页导航、点击、输入、截图等功能",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "timeout": 120,
      "enabled": true,
      "tools": [
        "browser_navigate",
        "browser_snapshot",
        "browser_click",
        "browser_input",
        "browser_scroll"
      ]
    },
    {
      "name": "windows",
      "description": "Windows 系统操作 - 提供鼠标点击、键盘输入、应用启动等功能",
      "command": "uvx",
      "args": ["windows-mcp"],
      "timeout": 60,
      "enabled": false,
      "tools": [
        "State-Tool",
        "Click-Tool",
        "Type-Tool",
        "Shortcut-Tool",
        "Scroll-Tool",
        "App-Tool",
        "Scrape-Tool"
      ]
    },
    {
      "name": "filesystem",
      "description": "文件系统操作 - 提供文件读取、写入、搜索等功能",
      "command": "npx",
      "args": [
        "@modelcontextprotocol/server-filesystem@latest",
        "C:\\Users\\iEZELL\\chinese-voice-assistant"
      ],
      "timeout": 60,
      "enabled": false,
      "tools": [
        "read_file",
        "write_file",
        "list_directory",
        "create_directory",
        "search_files"
      ]
    },
    {
      "name": "github",
      "description": "GitHub 操作 - 提供仓库管理、Issue、PR 等功能",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your-github-token-here"
      },
      "timeout": 60,
      "enabled": false,
      "tools": [
        "create_or_update_file",
        "search_repositories",
        "create_issue",
        "create_pull_request"
      ]
    }
  ],
  "_comments": {
    "name": "Server 唯一标识符",
    "description": "Server 功能描述",
    "command": "启动命令（如 npx, uvx, python）",
    "args": "命令参数列表",
    "env": "环境变量（可选）",
    "timeout": "启动超时时间（秒）",
    "enabled": "是否启用该 Server",
    "tools": "提供的工具列表（仅用于文档说明）"
  }
}
